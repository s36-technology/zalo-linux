{
  "name": "Zalo",
  "homepage": "https://zalo.me/",
  "version": "1.2.1",
  "description": "Zalo - Nhắn gửi yêu thương",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "npm": ">=11.13.0",
    "node": ">=26.2.0"
  },
  "lint-staged": {
    "*.{css,scss}": [
      "stylelint --config stylelint.config.js"
    ]
  },
  "scripts": {
    "dev": "ZALO_DISABLE_GPU=1 env -u ELECTRON_RUN_AS_NODE electron .",
    "dev:call": "ZALO_ENABLE_LINUX_CALL=1 ZALO_LINUX_CALL_EXPERIMENTAL=1 ZALO_LINUX_CALL_MEDIA_ENGINE=1 ZALO_DISABLE_GPU=1 env -u ELECTRON_RUN_AS_NODE electron .",
    "dev:call-mock": "ZALO_ENABLE_CALL_MOCK=1 ZALO_DISABLE_GPU=1 env -u ELECTRON_RUN_AS_NODE electron .",
    "dev:gpu": "env -u ELECTRON_RUN_AS_NODE electron .",
    "postinstall": "node scripts/install-electron-binary.js",
    "pack": "electron-builder --dir --publish never",
    "build": "electron-builder --linux AppImage deb snap --publish never",
    "build:appimage": "electron-builder --linux AppImage --publish never",
    "build:deb": "electron-builder --linux deb --publish never",
    "build:snap": "electron-builder --linux snap --publish never",
    "dist": "electron-builder --publish always"
  },
  "main": "bootstrap.js",
  "keywords": [
    "unofficial",
    "zalo-linux",
    "electron",
    "cross-platform"
  ],
  "author": {
    "name": "s36-technology",
    "email": "nnluc073@gmail.com",
    "url": "https://github.com/s36-technology"
  },
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "@babel/runtime-corejs3": "7.29.7",
    "@oneidentity/zstd-js": "1.0.3",
    "@reduxjs/toolkit": "2.12.0",
    "@sentry/electron": "7.13.0",
    "@sentry/react": "10.55.0",
    "@tensorflow/tfjs": "4.22.0",
    "@types/generic-pool": "3.8.3",
    "@types/node-fetch": "2.6.13",
    "adm-zip": "0.5.17",
    "ajv": "8.20.0",
    "archiver": "^8.0.0",
    "auto-launch": "^5.0.6",
    "babel-plugin-module-resolver": "5.0.3",
    "big-integer": "1.6.52",
    "bloom-filters": "3.0.4",
    "broadcast-channel": "~7.3.0",
    "buffer": "6.0.3",
    "cborg": "5.1.1",
    "change-case": "5.4.4",
    "chart.js": "4.5.1",
    "check-disk-space": "3.4.0",
    "cheerio": "1.2.0",
    "clsx": "2.1.1",
    "codemirror": "^5.65.21",
    "core-js": "3.49.0",
    "cron": "4.4.0",
    "crypto-js": "4.2.0",
    "decompress": "4.2.1",
    "dns-packet": "5.6.1",
    "dompurify": "3.4.7",
    "electron-log": "5.4.4",
    "electron-store": "11.0.2",
    "electron-updater": "6.8.3",
    "es6-promise": "4.2.8",
    "fast-glob": "3.3.3",
    "fast-memoize": "^2.5.2",
    "file-saver": "2.0.5",
    "file-type": "22.0.1",
    "flatted": "3.4.2",
    "follow-redirects": "1.16.0",
    "fs-extra": "11.3.5",
    "ftp": "0.3.10",
    "generic-pool": "3.9.0",
    "glob": "13.0.6",
    "google-protobuf": "4.0.2",
    "immer": "11.1.8",
    "jpeg-js": "0.4.4",
    "js-yaml": "^4.2.0",
    "jszip": "3.10.1",
    "libphonenumber-js": "^1.13.4",
    "lodash.debounce": "4.0.8",
    "lodash.toarray": "4.4.0",
    "lottie-web": "^5.13.0",
    "lowdb": "7.0.1",
    "lz-string": "1.5.0",
    "mediatr-ts": "2.2.0",
    "microm": "0.2.4",
    "mkdirp": "^3.0.1",
    "moment": "^2.30.1",
    "nanoid": "5.1.11",
    "node-fetch": "3.3.2",
    "node-stream-zip": "^1.15.0",
    "node-wifi": "2.0.16",
    "original-fs": "1.2.0",
    "p-defer": "4.0.1",
    "p-queue": "9.3.0",
    "p-tap": "4.0.0",
    "pako": "2.1.0",
    "percentile": "1.6.0",
    "progress-stream": "2.0.0",
    "prop-types": "15.8.1",
    "quick-lru": "7.3.0",
    "react": "19.2.7",
    "react-codemirror2": "^9.0.1",
    "react-custom-scrollbars": "^4.2.1",
    "react-datetime": "3.3.1",
    "react-dom": "19.2.7",
    "react-draggable": "^4.6.0",
    "react-error-overlay": "6.1.0",
    "react-input-range": "^1.3.0",
    "react-intersection-observer": "10.0.3",
    "react-measure": "2.5.2",
    "react-motion": "0.5.2",
    "react-redux": "9.3.0",
    "react-refresh": "0.18.0",
    "react-resizable": "^4.0.1",
    "react-router-redux": "^4.0.8",
    "react-simple-timefield": "3.3.1",
    "react-transition-group": "4.4.5",
    "react-virtualized": "9.22.6",
    "recoil": "0.7.7",
    "recompose": "0.30.0",
    "redux": "5.0.1",
    "redux-batched-subscribe": "0.1.6",
    "redux-thunk": "3.1.0",
    "reflect-metadata": "0.2.2",
    "reselect": "5.2.0",
    "resize-observer-polyfill": "1.5.1",
    "sax": "1.6.0",
    "seedrandom": "^3.0.5",
    "sift": "17.1.3",
    "source-map-support": "0.5.21",
    "spark-md5": "3.0.2",
    "stackblur-canvas": "3.0.1",
    "tar-fs": "3.1.2",
    "tmp": "0.2.7",
    "tough-cookie": "^6.0.1",
    "tsyringe": "4.10.0",
    "unload": "2.4.1",
    "unused-filename": "4.0.1",
    "uuid": "14.0.0",
    "web-vitals": "5.3.0",
    "workerpool": "10.0.2",
    "xstate": "5.32.0"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "s36-technology.zalo-linux",
    "productName": "Zalo Linux",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "bootstrap.js",
      "version.txt",
      "libs/**/*",
      "main-dist/**/*",
      "native/**/*",
      "pc-dist/**/*",
      "package.json",
      "!reverse-engineering/**/*",
      "!dist/**/*",
      "!node_modules/.cache/**/*"
    ],
    "linux": {
      "target": [
        "snap"
      ],
      "category": "Network",
      "icon": "pc-dist/favicon-512x512.png",
      "executableName": "zalo",
      "synopsis": "Zalo Messenger",
      "description": "Unofficial Linux port of Zalo desktop."
    },
    "deb": {
      "packageName": "zalo-linux",
      "maintainer": "Zalo Linux Community",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ]
    },
    "snap": {
      "confinement": "strict",
      "grade": "stable",
      "summary": "Zalo Messenger",
      "description": "Unofficial Linux port of Zalo desktop."
    }
  },
  "externals": []
}
